{
  "suite": "rag-quality-p0",
  "description": "Sprint 5 — Calidad RAG: grounding, retrieval, KPIs ARGOS, canary QA/prod allowlist",
  "sprint": 5,
  "threshold": {
    "top1_accuracy_min": 0.9,
    "grounded_response_rate_min": 0.95,
    "hallucination_rate_max": 0.02,
    "fallback_correct_min": 0.99,
    "retrieval_latency_max_ms": 400,
    "total_latency_max_ms": 1200,
    "citation_coverage_min": 0.95
  },
  "qa_canary": {
    "min_conversations": 100,
    "flags": {
      "RAG_P0_ENABLED": true,
      "RAG_INVENTORY_ENABLED": true,
      "RAG_RULES_ENABLED": true,
      "RAG_P0_ALLOWLIST": "5218181877351"
    }
  },
  "production": {
    "global_activation_forbidden": true,
    "allowlist_only": true
  },
  "scenarios": [
