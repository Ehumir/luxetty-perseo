{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://luxetty.dev/schemas/contextPackV1.json",
  "title": "ContextPackV1",
  "description": "Contrato RAG P0 — salida de retrieval para PERSEO V3. Sprint 2: schema only; no integración runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "context_pack_version",
    "sources",
    "citations",
    "scores",
    "confidence",
    "context_tokens_estimated",
    "chunks_selected",
    "chunks_dropped"
  ],
  "properties": {
    "context_pack_version": {
      "type": "string",
      "const": "1"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_type", "registry_domain_code", "source_id", "chunk_id"],
        "properties": {
          "source_type": { "type": "string" },
          "registry_domain_code": { "type": "string" },
          "source_id": { "type": "string", "format": "uuid" },
          "chunk_id": { "type": "string", "format": "uuid" },
          "document_id": { "type": "string", "format": "uuid" },
          "metadata": { "type": "object" }
        }
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["chunk_id", "rank", "score"],
        "properties": {
          "chunk_id": { "type": "string", "format": "uuid" },
          "rank": { "type": "integer", "minimum": 1 },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "excerpt": { "type": "string", "maxLength": 500 }
        }
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["top_score", "min_score_threshold"],
      "properties": {
        "top_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "min_score_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "avg_score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "0 = sin contexto recuperado (fallback seguro Sprint 3+)"
    },
    "context_tokens_estimated": {
      "type": "integer",
      "minimum": 0
    },
    "chunks_selected": {
      "type": "integer",
      "minimum": 0
    },
    "chunks_dropped": {
      "type": "integer",
      "minimum": 0
    },
    "fallback_used": {
      "type": "boolean",
      "default": false
    },
    "rag_query_log_id": {
      "type": "string",
      "format": "uuid"
    }
  }
}
