# Sprint 2 — Webhook PERSEO: en producción/staging debe ser true para que los toggles de ATENA
# (public.ai_conversation_channel_settings) bloqueen o permitan IA. Tras cambiar: reiniciar proceso.
PERSEO_POLICY_V2_ENABLED=true
# Solo durante validación P0: una línea JSON por inbound (perseo_policy_debug). Luego false o eliminar.
PERSEO_POLICY_DEBUG_LOG=false

# V3 — Motor conversacional productivo: solo `legacy` hasta rollout explícito (F0/F1).
PERSEO_ENGINE=legacy
# PERSEO_ENGINE=v3   # reservado; no activa V3 sin PERSEO_V3_ENABLED y cableado en webhook
PERSEO_V3_ENABLED=false
PERSEO_V3_SHADOW_MODE=false
PERSEO_V3_QA_ALLOWLIST=
# Solo diagnóstico: logs JSON línea con prefijo [V3]
PERSEO_V3_LOG=false

# V3-F2 — Solo números en allowlist reciben respuesta V3 (requiere PERSEO_V3_ENABLED=true)
# Ejemplo: PERSEO_V3_QA_ALLOWLIST=5218110000001,5218119999999

OPENAI_API_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
MEDIA_DOWNLOAD_ENABLED=true
MEDIA_DOWNLOAD_MAX_BYTES=
MEDIA_DOWNLOAD_TIMEOUT_MS=
AUDIO_TRANSCRIPTION_ENABLED=true
AUDIO_TRANSCRIPTION_MODEL=
AUDIO_TRANSCRIPTION_MAX_BYTES=
AUDIO_TRANSCRIPTION_TIMEOUT_MS=
IMAGE_VISION_ENABLED=true
IMAGE_VISION_MODEL=
IMAGE_VISION_MAX_BYTES=
IMAGE_VISION_TIMEOUT_MS=
