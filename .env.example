# Sprint 2 — Webhook PERSEO: en producción/staging debe ser true para que los toggles de ATENA
# (public.ai_conversation_channel_settings) bloqueen o permitan IA. Tras cambiar: reiniciar proceso.
PERSEO_POLICY_V2_ENABLED=true
# Solo durante validación P0: una línea JSON por inbound (perseo_policy_debug). Luego false o eliminar.
PERSEO_POLICY_DEBUG_LOG=false

# V3 — Motor conversacional productivo: solo `legacy` hasta rollout explícito (F0/F1).
PERSEO_ENGINE=legacy
# PERSEO_ENGINE=v3   # reservado; no activa V3 sin PERSEO_V3_ENABLED y cableado en webhook
# Maestro V3 primary (operativo). Alias documental: PERSEO_CONVERSATIONAL_CORE_V3_ENABLED (roadmap only).
PERSEO_V3_ENABLED=false
PERSEO_V3_SHADOW_MODE=false
PERSEO_V3_QA_ALLOWLIST=
# Solo diagnóstico: logs JSON línea con prefijo [V3]
PERSEO_V3_LOG=false
# F3.1 handoff + CRM dry-run (sin create lead real)
PERSEO_V3_HANDOFF_ENABLED=false
PERSEO_V3_CRM_DRY_RUN=true
# MC-6 — V3 primary en property entry / pauta sin expandir allowlist (rollback: false)
# PERSEO_V3_PROPERTY_ENTRY_AUTO_PRIMARY=false

# V3-F2 — Primary allowlist (NO requiere PERSEO_ENGINE=v3; PERSEO_ENGINE solo es log startup)
# Formato MX WhatsApp: 521 + 10 dígitos (ej. +52 81 1908 6196 → 5218119086196)
# PERSEO_V3_QA_ALLOWLIST=5218110000001,5218119999999
# QA primary: PERSEO_V3_SHADOW_MODE=false para evitar doble procesamiento

OPENAI_API_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# APA Notificaciones P0 — dispatch inmediato post-emit (default: SUPABASE_URL)
# NOTIFICATION_DISPATCHER_URL=
# NOTIFICATION_DISPATCH_SECRET=   # mismo valor que Edge Function + vault cron retry

# M4-04 staging-only (local .env — NO agregar en Railway prod hasta M4-05 explícito)
# PERSEO_ENV=staging
# PERSEO_STAGING_CONFIRMED=true
# PERSEO_BASE_URL_STAGING=https://<webhook-service>.up.railway.app
# VERIFY_TOKEN=luxetty_token
# PERSEO_CRM_WORKER_PROCESS_ENABLED=true   # (no PERSEO_CRM_WORKER_ENABLED — usar PROCESS)
# PERSEO_RUNTIME_OBSERVABILITY_ENABLED=true
# PERSEO_WA_TELEMETRY_ENABLED=true
# PERSEO_CRM_DURABILITY_ENABLED=true
# PERSEO_CRM_RUNTIME_PERSISTENT_ENABLED=true
# PERSEO_CRM_WORKER_ASYNC_ENABLED=true
# PERSEO_MEDIA_RUNTIME_PRODUCTION_ENABLED=true
# PERSEO_MEDIA_HARDENING_ENABLED=true
# PERSEO_MEDIA_RUNTIME_FAIL_OPEN_ENABLED=true
# PERSEO_RUNTIME_SAFETY_ENABLED=true
# PERSEO_REPLAY_ENGINE_ENABLED=true
# PERSEO_V3_CRM_EXECUTE=false
# PERSEO_ARGOS_ENABLED=false
# PERSEO_V3_ENABLED=true
# APA Intake Layer — hidratar ai_state desde intake_submissions (default OFF).
# PERSEO_APA_INTAKE_HYDRATION=false
# PERSEO_APA_INTAKE_WINDOW_HOURS=48
# PERSEO_APA_INTAKE_ALLOWLIST_ONLY=false  # true = solo PERSEO_V3_QA_ALLOWLIST (canary)

# M4-05a — flexibilidad conversacional (parsers slang/typos/ack MX). Default OFF.
# PERSEO_CONVERSATIONAL_FLEX_ENABLED=false
# PERSEO_V3_QA_ALLOWLIST=5218181877351,5218119086196,5218111654029
# M4_RAILWAY_REQUIRE_HEARTBEAT=true
# M4_WA_ALLOWLIST_MIN=3   # B1 smoke | default 10 for B2
# M4_WA_SMOKE_TIER=b1     # b1 | b2
MEDIA_DOWNLOAD_ENABLED=true
MEDIA_DOWNLOAD_MAX_BYTES=
MEDIA_DOWNLOAD_TIMEOUT_MS=
AUDIO_TRANSCRIPTION_ENABLED=true
AUDIO_TRANSCRIPTION_MODEL=
AUDIO_TRANSCRIPTION_MAX_BYTES=
AUDIO_TRANSCRIPTION_TIMEOUT_MS=
IMAGE_VISION_ENABLED=true
IMAGE_VISION_MODEL=
IMAGE_VISION_MAX_BYTES=
IMAGE_VISION_TIMEOUT_MS=
